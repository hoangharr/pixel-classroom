{
  "rules": {
    "world": {
      "config": {
        "meetStatus": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
        },
        "unlockedLessons": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
        }
      },
      "attendance": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && ($uid === auth.uid || auth.token.email == 'gigabyte.rp@gmail.com')"
        },
        ".write": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
      },
      "seats": {
        ".read": "auth != null",
        "$seatId": {
          ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || auth.token.email == 'gigabyte.rp@gmail.com')"
        },
        ".write": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
      },
      "events": {
        "teacherArrival": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
        }
      },
      "chat": {
        ".read": "auth != null",
        "$msgId": {
          ".write": "auth != null && (!data.exists() || auth.token.email == 'gigabyte.rp@gmail.com')"
        }
      },
      "players": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "registrations": {
      "trial": {
        ".write": "true",
        ".read": "auth != null && auth.token.email == 'gigabyte.rp@gmail.com'"
      }
    }
  }
}
